{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@rectify-dev/hook": ["../rectify-hook/src/index.ts"],
      "@rectify-dev/dom": ["../rectify-dom/src/index.ts"],
      "@rectify-dev/reconciler": ["../rectify-reconciler/src/index.ts"],
      "@rectify-dev/dom-binding": ["../rectify-dom-binding/src/index.ts"]
    }
  },
  "include": ["src", "*.ts"],
  "extends": "../../tsconfig.base.json"
}
