  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@babel/core": ">=7"
  }
}
